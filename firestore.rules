rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the user is authenticated and matches the requested userId
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper: Checks if the user is an admin or super admin.
    // Checks custom claims (e.g. role == "ADMIN" or role == "SUPER_ADMIN" inside custom Firebase token)
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.role == 'ADMIN' || 
        request.auth.token.role == 'SUPER_ADMIN'
      );
    }

    // Support Chats collection
    match /supportChats/{chatId} {
      
      // Helper to check if document is an order chat or guest chat
      function isOrderOrGuestChat() {
        return chatId.startsWith('order-') || 
               (resource != null && resource.data.isGuest == true) || 
               (request.resource != null && request.resource.data.isGuest == true) ||
               (resource != null && resource.data.type == 'order') ||
               (request.resource != null && request.resource.data.type == 'order');
      }

      // Allow read/list if user is the owner, an admin, or if it is an order/guest chat
      allow read: if isOrderOrGuestChat() || (
        request.auth != null && (
          isAdmin() || 
          resource.data.userId == request.auth.uid
        )
      );
      
      // Allow create if user is logged in (owner/admin) or creating an order/guest chat
      allow create: if isOrderOrGuestChat() || (
        request.auth != null && (
          isAdmin() || 
          request.resource.data.userId == request.auth.uid
        )
      );
      
      // Allow update if owner, admin, or order/guest chat
      allow update: if isOrderOrGuestChat() || (
        request.auth != null && (
          isAdmin() || 
          resource.data.userId == request.auth.uid
        )
      );

      // Allow delete if owner or admin
      allow delete: if request.auth != null && (
        isAdmin() || 
        resource.data.userId == request.auth.uid
      );
      
      // Messages subcollection
      match /messages/{messageId} {
        
        // Allow read, create, and update if order/guest chat or user is owner/admin
        allow read, create, update: if 
          chatId.startsWith('order-') ||
          get(/databases/$(database)/documents/supportChats/$(chatId)).data.isGuest == true ||
          get(/databases/$(database)/documents/supportChats/$(chatId)).data.type == 'order' || (
            request.auth != null && (
              isAdmin() || 
              get(/databases/$(database)/documents/supportChats/$(chatId)).data.userId == request.auth.uid
            )
          );

        // Only allow admins to delete individual chat messages
        allow delete: if request.auth != null && isAdmin();
      }
    }

    // Archived Chat Users collection (Admins and owners for auto-unarchive)
    match /archivedChatUsers/{userId} {
      allow read, write: if request.auth != null && (
        isAdmin() || 
        request.auth.uid == userId
      );
    }
    
    // Live Auctions collection (Public read for real-time live room telemetry)
    match /liveAuctions/{auctionId} {
      allow read: if true;
      allow create, delete: if request.auth != null && isAdmin();
      allow update: if (request.auth != null && isAdmin()) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewers']);
    }

    // Default deny rule for any other collection/document
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
