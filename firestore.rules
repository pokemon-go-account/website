rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the user is authenticated and matches the requested userId
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper: Checks if the user is an admin or super admin.
    // Checks custom claims (e.g. role == "ADMIN" or role == "SUPER_ADMIN" inside custom Firebase token)
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.role == 'ADMIN' || 
        request.auth.token.role == 'SUPER_ADMIN'
      );
    }

    // Support Chats collection
    match /supportChats/{chatId} {
      
      // Allow read/list if user is the owner or an admin
      allow read: if request.auth != null && (
        isAdmin() || 
        resource.data.userId == request.auth.uid
      );
      
      // Allow create if user is logged in and sets themselves as the owner (or is an admin)
      allow create: if request.auth != null && (
        isAdmin() || 
        request.resource.data.userId == request.auth.uid
      );
      
      // Allow update/delete if owner or admin
      allow update, delete: if request.auth != null && (
        isAdmin() || 
        resource.data.userId == request.auth.uid
      );
      
      // Messages subcollection
      match /messages/{messageId} {
        
        // Allow read/list and create if user is owner of the parent chat or admin
        allow read, create: if request.auth != null && (
          isAdmin() || 
          get(/databases/$(database)/documents/supportChats/$(chatId)).data.userId == request.auth.uid
        );
        
        // Allow update (such as marking read = true) if admin or owner of parent chat
        allow update: if request.auth != null && (
          isAdmin() || 
          get(/databases/$(database)/documents/supportChats/$(chatId)).data.userId == request.auth.uid
        );

        // Only allow admins to delete individual chat messages
        allow delete: if request.auth != null && isAdmin();
      }
    }
    
    // Default deny rule for any other collection/document
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
